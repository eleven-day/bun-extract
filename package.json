{
  "name": "bun-kit",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/bun-kit",
    "build:linux": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile dist/bun-kit-linux-x64",
    "build:windows": "bun build src/index.ts --compile --target=bun-windows-x64 --outfile dist/bun-kit-win-x64.exe",
    "build:all": "bun run build && bun run build:linux && bun run build:windows",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "generate-fixtures": "npx tsx tests/fixtures/generate.ts"
  },
  "dependencies": {
    "@kreuzberg/wasm": "^4.6.3",
    "@openrouter/sdk": "^0.10.2",
    "commander": "^12.1.0",
    "openai": "^6.33.0",
    "tesseract.js": "^7.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@google/genai": "^1.47.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "optionalDependencies": {
    "playwright": "^1.59.0"
  }
}
